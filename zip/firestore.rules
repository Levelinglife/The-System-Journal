rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - streak: number (required) - Current streak count
    //   - lastCheckin: string (optional) - Date of last check-in (YYYY-MM-DD)
    //   - startDate: string (optional) - Date the user started using the app (YYYY-MM-DD)
    //   - score: number (optional) - User's score
    //   - notificationTime: string (optional) - Time for morning briefing (HH:mm)
    //   - naggingEnabled: boolean (optional) - Whether nagging alerts are enabled
    //   - naggingFrequency: number (optional) - Frequency of nagging alerts in hours
    //
    // Collection: users/{userId}/goals
    // Document ID: {goalId}
    // Fields:
    //   - text: string (required) - The goal text
    //   - done: boolean (required) - Whether the goal is completed
    //   - date: string (required) - The date this goal belongs to (YYYY-MM-DD)
    //   - createdAt: timestamp (required) - Creation timestamp
    //
    // Collection: users/{userId}/journals
    // Document ID: {journalId}
    // Fields:
    //   - text: string (required) - The journal text
    //   - date: string (required) - The date this journal belongs to (YYYY-MM-DD)
    //   - createdAt: timestamp (required) - Creation timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // Domain Validators
    function isValidUser() {
      return hasOnlyAllowedFields(['streak', 'lastCheckin', 'startDate', 'score', 'notificationTime', 'naggingEnabled', 'naggingFrequency']) &&
             request.resource.data.streak is number &&
             request.resource.data.streak >= 0 &&
             (!('lastCheckin' in request.resource.data) || isValidDateString(request.resource.data.lastCheckin)) &&
             (!('startDate' in request.resource.data) || isValidDateString(request.resource.data.startDate)) &&
             (!('score' in request.resource.data) || request.resource.data.score is number) &&
             (!('notificationTime' in request.resource.data) || (request.resource.data.notificationTime is string && request.resource.data.notificationTime.matches("^\\d{2}:\\d{2}$"))) &&
             (!('naggingEnabled' in request.resource.data) || request.resource.data.naggingEnabled is bool) &&
             (!('naggingFrequency' in request.resource.data) || (request.resource.data.naggingFrequency is number && request.resource.data.naggingFrequency > 0));
    }

    function isValidGoal() {
      return hasOnlyAllowedFields(['text', 'done', 'date', 'createdAt']) &&
             request.resource.data.text is string &&
             request.resource.data.text.size() > 0 &&
             request.resource.data.text.size() <= 200 &&
             request.resource.data.done is bool &&
             isValidDateString(request.resource.data.date) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidJournal() {
      return hasOnlyAllowedFields(['text', 'date', 'createdAt']) &&
             request.resource.data.text is string &&
             request.resource.data.text.size() > 0 &&
             request.resource.data.text.size() <= 5000 &&
             isValidDateString(request.resource.data.date) &&
             request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
      allow delete: if false; // Users shouldn't be deleted directly from client

      match /goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal();
        allow update: if isOwner(userId) && isValidGoal() &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }

      match /journals/{journalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJournal();
        allow update: if isOwner(userId) && isValidJournal() &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}
