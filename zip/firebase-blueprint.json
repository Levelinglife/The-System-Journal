{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and streak tracking",
      "type": "object",
      "properties": {
        "streak": {
          "type": "number",
          "description": "Current streak count"
        },
        "lastCheckin": {
          "type": "string",
          "description": "Date of last check-in (YYYY-MM-DD)"
        },
        "startDate": {
          "type": "string",
          "description": "Date the user started using the app (YYYY-MM-DD)"
        },
        "score": {
          "type": "number",
          "description": "User's score"
        },
        "notificationTime": {
          "type": "string",
          "description": "Time for morning briefing (HH:mm)"
        },
        "naggingEnabled": {
          "type": "boolean",
          "description": "Whether nagging alerts are enabled"
        },
        "naggingFrequency": {
          "type": "number",
          "description": "Frequency of nagging alerts in hours"
        }
      },
      "required": ["streak"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A daily goal",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The goal text"
        },
        "done": {
          "type": "boolean",
          "description": "Whether the goal is completed"
        },
        "date": {
          "type": "string",
          "description": "The date this goal belongs to (YYYY-MM-DD)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["text", "done", "date", "createdAt"]
    },
    "Journal": {
      "title": "Journal",
      "description": "A journal entry",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The journal text"
        },
        "date": {
          "type": "string",
          "description": "The date this journal belongs to (YYYY-MM-DD)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["text", "date", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "users/{userId}/goals/{goalId}": {
      "schema": {
        "$ref": "#/entities/Goal"
      },
      "description": "User's daily goals"
    },
    "users/{userId}/journals/{journalId}": {
      "schema": {
        "$ref": "#/entities/Journal"
      },
      "description": "User's journal entries"
    }
  }
}
